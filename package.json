{
  "name": "piplus",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:api": "bun run apps/api/src/index.ts",
    "dev:web": "cd apps/web && bun run dev",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "typecheck": "cd apps/api && bun run typecheck && cd ../web && bun run lint && cd ../desktop && bun run typecheck && cd ../../packages/db && bun run typecheck && cd ../domain && bun run typecheck && cd ../pi-client && bun run typecheck && cd ../shared && bun run typecheck",
    "typecheck:desktop": "cd apps/desktop && bun run typecheck",
    "build:desktop": "bash scripts/build-desktop.sh",
    "test": "cd apps/api && bun test",
    "test:api": "cd apps/api && bun test",
    "test:web": "cd apps/web && bun test",
    "update-role-prompts": "bun run scripts/update-role-prompts.ts"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "bun-types": "^1.3.14",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.10"
  }
}
