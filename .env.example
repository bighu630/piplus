# ─── Database ───────────────────────────────────
DATABASE_URL=file:./piplus.sqlite

# ─── Auth (generate with: openssl rand -base64 32) ─
AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3001

# ─── Server ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
LOG_LEVEL=info

# ─── Production / Cloudflare Tunnel ───────────────
# Set this to your public URL to serve web + API together
# PUBLIC_WEB_ORIGIN=https://piplus.whosworld.fun
# PIPLUS_WEB_DIST=./apps/web/dist

# ─── Role prompts ─────────────────────────────────
# PIPLUS_FORCE_ROLE_PROMPTS=true
